{
  "name": "optimark-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/apollo && bun run dev",
    "build": "cd apps/apollo && bun run build",
    "check": "cd apps/apollo && bun run check",
    "preview": "cd apps/apollo && bun run preview"
  }
}
