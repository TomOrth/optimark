# Postgres
POSTGRES_DB=optimark
POSTGRES_USER=optimark
POSTGRES_PASSWORD=optimark
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# SeaweedFS
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_FILER_PORT=8888
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_ACCESS_KEY=admin
SEAWEEDFS_SECRET_KEY=key

# Backend application defaults
BACKEND_DATABASE_URL=postgresql+psycopg://optimark:optimark@localhost:5432/optimark
BACKEND_REDIS_URL=redis://localhost:6379/0
BACKEND_S3_ENDPOINT_URL=http://localhost:8333
BACKEND_S3_REGION=us-east-1
BACKEND_S3_BUCKET=optimark-dev
BACKEND_S3_ACCESS_KEY_ID=admin
BACKEND_S3_SECRET_ACCESS_KEY=key
BACKEND_AUTH_SESSION_COOKIE_NAME=optimark_session
BACKEND_AUTH_SESSION_TTL_DAYS=14
BACKEND_AUTH_SESSION_COOKIE_SECURE=false
BACKEND_AUTH_SESSION_COOKIE_SAME_SITE=lax
